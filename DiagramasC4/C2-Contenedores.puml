@startuml C4_Component_SistemaPiedraAzul
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Sistema Piedra Azul - Diagrama de Componentes
title Contenedor: Aplicación de escritorio

Person(admin, "Administrador")
Person(agendador, "Agendador")
Person(medico, "Médico / Terapista")

ContainerDb(db, "Base de datos relacional", "MariaDB / PostgreSQL", "Persistencia del sistema")
System_Ext(csvtool, "Herramienta de hojas de cálculo", "Abre exportaciones CSV")

Container_Boundary(app, "Aplicación de escritorio - Sistema Piedra Azul") {

    Component(ui, "Interfaz de usuario", "JavaFX + FXML", "Pantallas del sistema: login, panel administrador, panel agendador, panel médico, historia clínica y reportes")

    Component(auth, "Autenticación y control de acceso", "Controller + Service", "Valida credenciales, controla inicio de sesión y restringe funcionalidades según rol")

    Component(usuarios, "Gestión de usuarios", "Controller + Service", "Administra usuarios del sistema, roles y datos administrativos")

    Component(medicos, "Gestión de médicos y terapistas", "Controller + Service", "Registra, consulta y actualiza médicos o terapistas")

    Component(pacientes, "Gestión de pacientes", "Controller + Service", "Registra, consulta y actualiza los datos básicos del paciente")

    Component(citas, "Gestión de citas", "Controller + Service", "Agenda, reprograma, cancela y consulta citas; valida disponibilidad y genera listados diarios")

    Component(historia, "Historia clínica básica", "Controller + Service", "Permite consultar pacientes y registrar información clínica básica durante la atención")

    Component(auditoria, "Auditoría del sistema", "Service", "Registra eventos relevantes como inicios de sesión, cambios y operaciones sensibles")

    Component(reportes, "Reportes y exportación", "Service", "Genera listados por fecha/médico y exporta la agenda en CSV")

    Component(persistencia, "Persistencia", "Spring Data JPA", "Abstrae el acceso a usuarios, pacientes, médicos, citas, historia clínica y auditoría")

}

Rel(admin, ui, "Usa")
Rel(agendador, ui, "Usa")
Rel(medico, ui, "Usa")

Rel(ui, auth, "Invoca")
Rel(ui, usuarios, "Invoca")
Rel(ui, medicos, "Invoca")
Rel(ui, pacientes, "Invoca")
Rel(ui, citas, "Invoca")
Rel(ui, historia, "Invoca")
Rel(ui, reportes, "Invoca")

Rel(auth, persistencia, "Consulta")
Rel(usuarios, persistencia, "Usa")
Rel(medicos, persistencia, "Usa")
Rel(pacientes, persistencia, "Usa")
Rel(citas, persistencia, "Usa")
Rel(historia, persistencia, "Usa")
Rel(auditoria, persistencia, "Usa")
Rel(reportes, persistencia, "Consulta")

Rel(persistencia, db, "Lee/Escribe", "SQL")
Rel(reportes, csvtool, "Genera archivos", "CSV")

@enduml
